         <property name="styleSheet">
          <string notr="true">/* 基础样式（包含图标） */
QPushButton {
    border-image: url(:/icons/icons/home.png);
    background: transparent; /* 防止背景覆盖 */
    border: none;            /* 移除默认边框 */
    padding: 0px;            /* 确保图片不被内边距挤压 */
}

/* 鼠标悬停效果 */
QPushButton:hover {
    background:rgb(40, 74, 117);     /* 悬停时覆盖背景色 */
}

/* 按下效果 */
QPushButton:pressed {
    background: #4B6C8A;     /* 按下时覆盖背景色 */
}</string>
